diff --git a/src/java.desktop/unix/classes/sun/awt/wl/WLDataTransferer.java b/src/java.desktop/unix/classes/sun/awt/wl/WLDataTransferer.java
index a7ad424..8e0556d 100644
--- a/src/java.desktop/unix/classes/sun/awt/wl/WLDataTransferer.java
+++ b/src/java.desktop/unix/classes/sun/awt/wl/WLDataTransferer.java
@@ -406,6 +406,18 @@ public class WLDataTransferer extends DataTransferer {
             }
 
             for (String encoding : DataFlavorUtil.standardEncodings()) {
+                // ChromeOS/Exo clipboard fix (JBR-7721).
+                // The ChromeOS Exo compositor always prefers
+                // text/plain;charset=UTF-16 whenever it is offered, but the
+                // bytes served for that native are encoded with the platform
+                // default charset (UTF-8) rather than UTF-16, so Exo decodes
+                // them as UTF-16 and turns each ASCII pair into one CJK
+                // codepoint. Skip the UTF-16 family under Exo so it falls back
+                // to UTF-8, which round-trips correctly. Behaviour is unchanged
+                // on every other Wayland compositor.
+                if (WLToolkit.isExoCompositor() && encoding.startsWith("UTF-16")) {
+                    continue;
+                }
                 if (!encoding.equals(charset)) {
                     natives.add(baseType + ";charset=" + encoding);
                 }
